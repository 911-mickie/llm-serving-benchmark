# Copy this file to the appropriate .env variant and fill in your values.
#
# Variants used in this repo:
#   .env                  — vLLM, Qwen2.5-7B-Instruct FP16 (used by docker-compose.yml)
#   .env.qwen.vllm        — same as above, explicit name
#   .env.qwen.sglang      — SGLang, Qwen2.5-7B-Instruct FP16
#   .env.qwen-awq.vllm    — vLLM, Qwen2.5-7B-Instruct-AWQ
#   .env.qwen-awq.sglang  — SGLang, Qwen2.5-7B-Instruct-AWQ
#   .env.sglang           — SGLang baseline (alias for .env.qwen.sglang)

# ── vLLM ──────────────────────────────────────────────────────────────────────
VLLM_IMAGE=vllm/vllm-openai:v0.8.5
CONTAINER_NAME=vllm-qwen25-7b-instruct
HOST_PORT=8001

# ── SGLang ────────────────────────────────────────────────────────────────────
# Use lmsysorg/sglang:v0.4.9.post6-cu126 for FP16, sglang-awq-vllmops:local for AWQ.
SGLANG_IMAGE=lmsysorg/sglang:v0.4.9.post6-cu126
SGLANG_CONTAINER_NAME=sglang-qwen25-7b-instruct
SGLANG_HOST_PORT=30000
SGLANG_CONTAINER_PORT=30000
SGLANG_MEM_FRACTION_STATIC=0.92
SGLANG_CONTEXT_LENGTH=2048
SGLANG_MAX_RUNNING_REQUESTS=4

# ── Model ─────────────────────────────────────────────────────────────────────
# FP16 baseline:  Qwen/Qwen2.5-7B-Instruct
# AWQ quantized:  Qwen/Qwen2.5-7B-Instruct-AWQ
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# ── Serving limits ────────────────────────────────────────────────────────────
GPU_MEMORY_UTILIZATION=0.90
MAX_MODEL_LEN=2048
MAX_NUM_SEQS=4
DTYPE=float16

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Required to download gated models. Get a token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_YOUR_TOKEN_HERE
# Absolute path to your local HuggingFace cache directory (avoids re-downloading weights).
HF_CACHE=~/.cache/huggingface
